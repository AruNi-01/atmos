# Backend API URL (REST)
# NEXT_PUBLIC_API_URL=http://100.x.x.x:30303

# Backend WebSocket URL
# NEXT_PUBLIC_WS_URL=ws://100.x.x.x:30303

# APP-016 Atmos Computer — Cloudflare control plane HTTPS origin (optional default in Settings UI)
# NEXT_PUBLIC_ATMOS_CP_URL=https://relay.atmos.land

# Tldraw license key
# NEXT_PUBLIC_TLDRAW_LICENSE_KEY=your_tldraw_license_key
