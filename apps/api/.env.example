# Runtime environment: development | production
# In production, CORS_ORIGIN must be explicitly set
# RUST_ENV=production

# Server bind address
SERVER_HOST=0.0.0.0
SERVER_PORT=30303
ATMOS_PORT=30303
ATMOS_LOCAL_TOKEN=

# CORS allowed origins
# Use "*" to allow all origins (dev only), or comma-separated list:
# CORS_ORIGIN=https://atmos.example.com,https://app.example.com
CORS_ORIGIN=*
# Desktop default origins:
# CORS_ORIGIN=http://localhost:3030,tauri://localhost,https://tauri.localhost
