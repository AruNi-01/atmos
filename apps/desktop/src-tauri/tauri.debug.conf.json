{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Atmos",
  "version": "0.1.0",
  "identifier": "com.atmos.desktop",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "http://localhost:3030",
    "beforeBuildCommand": "node ../../scripts/desktop/before-build.mjs",
    "frontendDist": "../../web/out"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "splashscreen",
        "url": "/splashscreen.html",
        "width": 1400,
        "height": 900,
        "center": true,
        "resizable": true,
        "decorations": true,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 14,
          "y": 20
        },
        "alwaysOnTop": true,
        "visible": true
      },
      {
        "label": "main",
        "title": "Atmos",
        "url": "/",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 14,
          "y": 20
        },
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/api"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhEMjIwOUIxMDAzQ0RGM0IKUldRNzN6d0FzUWtpalFBdkU2WWM4NmxlcGZTZ2M4ejR6dVh0R05lNkFINW9YcmpKRWJRbFhTQmwK",
      "endpoints": [
        "https://github.com/AruNi-01/atmos/releases/latest/download/latest.json"
      ]
    }
  }
}
