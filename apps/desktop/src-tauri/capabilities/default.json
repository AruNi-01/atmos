{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability set for Atmos desktop",
  "windows": [
    "main",
    "splashscreen",
    "appshot-permissions"
  ],
  "webviews": ["preview-inspector"],
  "remote": {
    "urls": [
      "http://127.0.0.1:*",
      "http://localhost:*",
      "https://127.0.0.1:*",
      "https://localhost:*",
      "https://relay.atmos.land",
      "https://*.atmos.land",
      "wss://relay.atmos.land",
      "wss://*.atmos.land"
    ]
  },
  "permissions": [
    "core:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-close",
    "core:window:allow-set-focus",
    "core:window:allow-start-dragging",
    "shell:default",
    "notification:allow-notify",
    "opener:default",
    "updater:default",
    "process:allow-exit",
    "process:allow-restart"
  ]
}
