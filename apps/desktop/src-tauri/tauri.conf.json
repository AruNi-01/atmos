{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Atmos",
  "version": "1.2.0-beta.11",
  "identifier": "com.atmos.desktop",
  "build": {
    "beforeDevCommand": "bun --filter web dev",
    "beforeBuildCommand": "node ../../scripts/desktop/before-build.mjs",
    "devUrl": "http://localhost:3030",
    "frontendDist": "../../web/out"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "splashscreen",
        "url": "/splashscreen.html",
        "width": 1400,
        "height": 900,
        "center": true,
        "resizable": true,
        "decorations": true,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 14,
          "y": 21
        },
        "alwaysOnTop": true,
        "visible": true
      },
      {
        "label": "main",
        "title": "Atmos",
        "url": "/",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "dragDropEnabled": false,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 14,
          "y": 21
        },
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self' http://127.0.0.1:* http://localhost:* ws://127.0.0.1:* ws://localhost:* wss://127.0.0.1:* wss://localhost:*; connect-src 'self' http://127.0.0.1:* http://localhost:* ws://127.0.0.1:* ws://localhost:* wss://127.0.0.1:* wss://localhost:* https://relay.atmos.land wss://relay.atmos.land https://*.atmos.land wss://*.atmos.land https://github.com; img-src 'self' data: blob: https:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "binaries/runtime/current": "runtime/current",
      "binaries/web-out": "web-out",
      "binaries/system-skills": "system-skills",
      "binaries/atmos-cli": "atmos-cli",
      "icons/icon.icns": "AtmosSidecar.icns"
    },
    "windows": {
      "wix": {
        "version": "1.2.0.11"
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhEMjIwOUIxMDAzQ0RGM0IKUldRNzN6d0FzUWtpalFBdkU2WWM4NmxlcGZTZ2M4ejR6dVh0R05lNkFINW9YcmpKRWJRbFhTQmwK",
      "endpoints": [
        "https://github.com/AruNi-01/atmos/releases/latest/download/latest.json"
      ]
    }
  }
}
