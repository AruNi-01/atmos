{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Project Wiki Evidence Bundle",
  "type": "object",
  "required": [
    "page_id",
    "files",
    "symbols",
    "relations",
    "commits",
    "issues",
    "prs",
    "inferences"
  ],
  "properties": {
    "page_id": { "type": "string" },
    "files": {
      "type": "array",
      "items": { "type": "string" }
    },
    "symbols": {
      "type": "array",
      "items": { "type": "string" }
    },
    "relations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "commits": {
      "type": "array",
      "items": { "type": "string" }
    },
    "issues": {
      "type": "array",
      "items": { "type": "string" }
    },
    "prs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "inferences": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
