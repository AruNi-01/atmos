{
  "name": "atmos",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --filter web dev",
    "dev:web": "bun --filter web dev",
    "dev:landing": "bun --filter landing dev",
    "dev:docs": "bun --filter docs dev",
    "build": "bun run build:packages && bun run build:apps",
    "build:packages": "bun --filter '@atmos/*' run build",
    "build:apps": "bun --filter web --filter landing --filter docs run build",
    "build:web": "bun --filter web build",
    "lint": "bun --filter '*' lint",
    "lint:web": "bun --filter web lint",
    "typecheck": "bun --filter '*' typecheck",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules"
  },
  "catalog": {
    "comment": "Unified management of core dependent versions of all front-end projects",
    "next": "16.1.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwindcss": "^4",
    "@tailwindcss/postcss": "^4",
    "next-intl": "^4.7.0",
    "next-themes": "^0.4.6",
    "typescript": "^5",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.2",
    "tw-animate-css": "^1.4.0"
  }
}
